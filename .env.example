# Horizons Travel RAG - Environment Configuration
# Copy this file to .env and fill in your actual API keys

# ============================================================================
# REQUIRED: Groq API Key
# Get your free API key from: https://groq.com
# ============================================================================
GROQ_API_KEY=your_groq_api_key_here

# ============================================================================
# OPTIONAL: Google Gemini API (for alternative LLM provider)
# Get your API key from: https://aistudio.google.com
# ============================================================================
GOOGLE_API_KEY=your_google_gemini_api_key_here

# ============================================================================
# Application Settings
# ============================================================================

# Enable caching for faster retrieval
USE_CACHE=true

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ============================================================================
# CSV Data Path (only change if you move the data file)
# ============================================================================
DATA_PATH=data/processed/travel_data.csv
